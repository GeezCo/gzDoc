# Application
APP_NAME=gzdoc-ai-service
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://gzdoc:gzdoc123@localhost:5432/gzdoc

# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-3-small

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_DOCUMENT_PARSE=document-parse
KAFKA_TOPIC_DOCUMENT_VECTORIZE=document-vectorize

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gzdoc
MINIO_SECURE=False
